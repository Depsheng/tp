@startuml
!include style.puml
skin rose
skinparam ActivityFontSize 15
skinparam ArrowFontSize 12

start
:Input date/time string;

if () then ([Relative date?])
    :Resolve base date;
    note right
    today -> current date
    tomorrow -> current date + 1
    weekday -> next matching weekday
    end note

    if () then ([Has time component?])
        :Parse provided time;
    else ([else])
        :Use default time 23:59;
    endif

    :Validate not in past;
else ([else])
    :Pass input to explicit date/time parsing;
endif

:Return DateTimeParseResult;
stop
@enduml
