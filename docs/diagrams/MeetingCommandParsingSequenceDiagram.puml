@startuml
!include style.puml
skinparam ArrowFontStyle plain

box Logic LOGIC_COLOR_T1
participant ":AddressBookParser" as AddressBookParser LOGIC_COLOR
participant ":MeetingCommandParser" as MeetingCommandParser LOGIC_COLOR
participant "m:MeetingCommand" as MeetingCommand LOGIC_COLOR
end box

box "Commons Util" LOGIC_COLOR_T1
participant "DateTimeUtil" as DateTimeUtil LOGIC_COLOR
end box

[-> AddressBookParser : parseCommand("meeting 1 15 Mar 2026 4pm")
activate AddressBookParser

create MeetingCommandParser
AddressBookParser -> MeetingCommandParser : MeetingCommandParser()
activate MeetingCommandParser
MeetingCommandParser --> AddressBookParser
deactivate MeetingCommandParser

AddressBookParser -> MeetingCommandParser : parse("1 15 Mar 2026 4pm")
activate MeetingCommandParser

MeetingCommandParser -> MeetingCommandParser : parse index
MeetingCommandParser -> DateTimeUtil : parseDateTime("15 Mar 2026 4pm")
activate DateTimeUtil

DateTimeUtil --> MeetingCommandParser : DateTimeParseResult
deactivate DateTimeUtil

create MeetingCommand
MeetingCommandParser -> MeetingCommand : MeetingCommand(index, meeting)
activate MeetingCommand
MeetingCommand --> MeetingCommandParser
deactivate MeetingCommand

MeetingCommandParser --> AddressBookParser : m
deactivate MeetingCommandParser
MeetingCommandParser -[hidden]-> AddressBookParser
destroy MeetingCommandParser

[<-- AddressBookParser : m
deactivate AddressBookParser
@enduml
